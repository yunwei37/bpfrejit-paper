        <mxCell id="SbqmE6-mlqRPoa65LsV4-3" value="&lt;div&gt;r_tmp = r_x&lt;/div&gt;&lt;div&gt;r_tmp &amp;gt;&amp;gt;= 48&lt;/div&gt;&lt;div&gt;r_dst = r_x&lt;/div&gt;&lt;div&gt;r_dst &amp;lt;&amp;lt;= 16&lt;/div&gt;&lt;div&gt;r_dst |= r_tmp&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;" parent="1" vertex="1">
          <mxGeometry x="600" y="560" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="SbqmE6-mlqRPoa65LsV4-4" value="&lt;div&gt;mov rcx, rdi&lt;/div&gt;&lt;div&gt;shr rcx, 48&lt;/div&gt;&lt;div&gt;mov rax, rdi&lt;/div&gt;&lt;div&gt;shl rax, 16&lt;/div&gt;&lt;div&gt;or&amp;nbsp; rax, rcx&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;" parent="1" vertex="1">
          <mxGeometry x="780" y="560" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="SbqmE6-mlqRPoa65LsV4-5" value="&lt;div&gt;mov rax, rdi&lt;/div&gt;&lt;div&gt;rol rax, 16&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;align=left;" parent="1" vertex="1">
          <mxGeometry x="780" y="680" width="160" height="80" as="geometry" />
        </mxCell>
